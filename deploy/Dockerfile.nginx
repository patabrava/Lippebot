FROM node:22-alpine AS widget-builder

WORKDIR /app/widget
COPY widget/package*.json ./
RUN npm ci
COPY widget/ ./
RUN npm run build

FROM nginx:alpine

COPY --from=widget-builder /app/widget/dist /usr/share/nginx/html
COPY deploy/widget-test-index.html /usr/share/nginx/html/index.html
COPY deploy/nginx.vps.conf /etc/nginx/conf.d/default.conf
